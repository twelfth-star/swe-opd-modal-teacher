# Teacher config for Qwen/Qwen3.5-35B-A3B-FP8 with tp=4 on 4×A100 40GB.
# Used for swe-opt-training OPD.
#
# Usage:
#   cp config/bootstrap/modal_teacher_qwen35_35b.env config/bootstrap/modal_teacher.local.env
#   # edit as needed, then: bash scripts/deploy.sh

MODAL_APP_NAME=swe-opd-teacher-qwen35-35b
MODAL_REGION=us-east
MODAL_PROXY_REGIONS=us-east

# 1 replica × 4 A100 GPUs (tp=4)
MODAL_DP_REPLICAS=1
MODAL_MIN_CONTAINERS=1
MODAL_MAX_CONTAINERS=1

# Per-container GPU request: 4×A100 40GB
MODAL_GPU_CONFIG="A100:4"
SGLANG_TP_SIZE=4

# Allow up to 8 concurrent requests per replica
MODAL_TARGET_INPUTS=8
MODAL_SCALEDOWN_WINDOW_SECONDS=1800
MODAL_EXIT_GRACE_PERIOD_SECONDS=25

# Base image — v0.5.9 has day-zero support for qwen3_5_moe natively
MODAL_BASE_IMAGE=lmsysorg/sglang:v0.5.9-cu129-amd64-runtime
MODAL_HF_CACHE_VOLUME_NAME=swe-opd-modal-teacher-hf-cache

HF_CACHE_PATH=/root/.cache/huggingface
HF_HOME_PATH=/root/.cache/huggingface

# Teacher model
SGLANG_MODEL_PATH=Qwen/Qwen3.5-35B-A3B-FP8
SGLANG_MODEL_REVISION=
SGLANG_SERVED_MODEL_NAME=Qwen/Qwen3.5-35B-A3B-FP8
SGLANG_HOST=0.0.0.0
SGLANG_PORT=8000
SGLANG_MEM_FRACTION_STATIC=0.85
SGLANG_CONTEXT_LENGTH=32768
SGLANG_API_KEY=swe-opd-teacher-key-2026

# Qwen3.5 MoE: trust-remote-code required; chunked-prefill helps throughput
SGLANG_EXTRA_ARGS="--trust-remote-code --chunked-prefill-size 8192"

PREFETCH_TIMEOUT_SECONDS=7200
SGLANG_STARTUP_TIMEOUT_SECONDS=1800
SGLANG_ENABLE_WARMUP=false
SGLANG_WARMUP_REPEATS=1
SGLANG_WARMUP_MAX_TOKENS=8

# Fill in after deployment:
# TEACHER_BASE_URL=https://...modal.run
