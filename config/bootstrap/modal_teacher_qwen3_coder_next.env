# Modal teacher: Qwen/Qwen3-30B-A3B-Instruct-2507 on 2x A100-80GB, tp=2

# Modal app identity and placement.
MODAL_APP_NAME=swe-opd-teacher-qwen3-coder-next
MODAL_REGION=us-east
MODAL_PROXY_REGIONS=us-east

# Fixed deployment: 1 replica (4 GPUs each).
MODAL_DP_REPLICAS=1
MODAL_MIN_CONTAINERS=1
MODAL_MAX_CONTAINERS=1

# 2x A100-80GB per container, tp=2.
MODAL_GPU_CONFIG=A100-80GB:2
SGLANG_TP_SIZE=2

# Concurrency.
MODAL_TARGET_INPUTS=4
MODAL_SCALEDOWN_WINDOW_SECONDS=1800
MODAL_EXIT_GRACE_PERIOD_SECONDS=25

# Base image.
MODAL_BASE_IMAGE=lmsysorg/sglang:v0.5.6.post2-cu129-amd64-runtime
MODAL_HF_CACHE_VOLUME_NAME=swe-opd-modal-teacher-hf-cache

# Cache paths.
HF_CACHE_PATH=/root/.cache/huggingface
HF_HOME_PATH=/root/.cache/huggingface

# SGLang server settings.
SGLANG_MODEL_PATH=Qwen/Qwen3-30B-A3B-Instruct-2507
SGLANG_MODEL_REVISION=
SGLANG_SERVED_MODEL_NAME=Qwen/Qwen3-30B-A3B-Instruct-2507
SGLANG_HOST=0.0.0.0
SGLANG_PORT=8000
SGLANG_MEM_FRACTION_STATIC=0.80
SGLANG_CONTEXT_LENGTH=0
SGLANG_API_KEY=CHANGE_ME
SGLANG_EXTRA_ARGS=--trust-remote-code

# Startup and warmup.
PREFETCH_TIMEOUT_SECONDS=7200
SGLANG_STARTUP_TIMEOUT_SECONDS=1800
SGLANG_ENABLE_WARMUP=true
SGLANG_WARMUP_REPEATS=2
SGLANG_WARMUP_MAX_TOKENS=8

# Filled after deployment.
TEACHER_BASE_URL=
