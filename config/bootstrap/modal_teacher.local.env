# Copy to config/bootstrap/modal_teacher.local.env and edit.

# Modal app identity and placement.
MODAL_APP_NAME=swe-opd-modal-teacher-fixed
MODAL_REGION=us-east
MODAL_PROXY_REGIONS=us-east

# Fixed deployment size.
# One Modal container = one DP replica.
N=2
MODAL_DP_REPLICAS=${N}
MODAL_MIN_CONTAINERS=${N}
MODAL_MAX_CONTAINERS=${N}

# Per-container GPU request. This should match TP size.
# Examples: A100:1, A100:2, A100-80GB:4
M=2
MODAL_GPU_CONFIG="A100:${M}"
SGLANG_TP_SIZE=${M}

# Concurrency inside each replica.
MODAL_TARGET_INPUTS=4
MODAL_SCALEDOWN_WINDOW_SECONDS=1800
MODAL_EXIT_GRACE_PERIOD_SECONDS=25

# Base image and optional Hugging Face secret already created in Modal.
MODAL_BASE_IMAGE=lmsysorg/sglang:v0.5.6.post2-cu129-amd64-runtime
# MODAL_HF_SECRET_NAME=huggingface-secret
MODAL_HF_CACHE_VOLUME_NAME=swe-opd-modal-teacher-hf-cache

# Cache paths inside the container.
HF_CACHE_PATH=/root/.cache/huggingface
HF_HOME_PATH=/root/.cache/huggingface

# SGLang server settings.
SGLANG_MODEL_PATH=Qwen/Qwen3-8B
SGLANG_MODEL_REVISION=
SGLANG_SERVED_MODEL_NAME=Qwen/Qwen3-8B
SGLANG_HOST=0.0.0.0
SGLANG_PORT=8000
SGLANG_MEM_FRACTION_STATIC=0.80
SGLANG_CONTEXT_LENGTH=32000
SGLANG_API_KEY=123456789abcdef
# Example: --trust-remote-code
SGLANG_EXTRA_ARGS="--trust-remote-code"

# Startup and warmup.
PREFETCH_TIMEOUT_SECONDS=7200
SGLANG_STARTUP_TIMEOUT_SECONDS=1800
SGLANG_ENABLE_WARMUP=false
SGLANG_WARMUP_REPEATS=2
SGLANG_WARMUP_MAX_TOKENS=8

# Filled after deployment for local smoke tests.
TEACHER_BASE_URL=https://susvibes-mitigation--swe-opd-modal-teacher-fixed-teacher-601251.modal.run